{
  "name": "snumber.js",
  "version": "0.2.0",
  "description": "A chainable, functional number utility for precise decimal calculations",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/snumber.cjs",
  "module": "./dist/snumber.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/snumber.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/snumber.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "test": "vitest run",
    "build": "vite build && vite build --mode minify",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "number",
    "math",
    "chainable",
    "decimal",
    "precision",
    "utility"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bryanlee-hao/snumber"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
